generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Organization {
  id                      String                @id @default(cuid())
  name                    String
  slug                    String                @unique
  logo                    String?
  subscriptionTier        String                @default("free")
  subscriptionStatus      String                @default("active")
  stripeCustomerId        String?               @unique
  stripeSubscriptionId    String?               @unique
  maxEmployees            Int                   @default(10)
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  planType                String                @default("free")
  planStatus              String                @default("active")
  employeeLimit           Int                   @default(5)
  storageLimit            Float                 @default(1)
  currentPeriodEnd        DateTime?
  trialEndsAt             DateTime?
  bpjsKesehatanRate       Decimal               @default(1) @db.Decimal(5, 2)
  bpjsKetenagakerjaanRate Decimal               @default(2) @db.Decimal(5, 2)
  payrollDayOfMonth       Int                   @default(25)
  autoApproveBelow        Int                   @default(0)
  leaveApprovalLevels     Int                   @default(1)
  requireHrApprovalAbove  Int                   @default(5)
  attendance              Attendance[]
  departments             Department[]
  employees               Employee[]
  leaves                  Leave[]
  leaveRequests           LeaveRequest[]
  notifications           Notification[]
  settings                OrganizationSettings?
  payrolls                Payroll[]
  salaryComponents        SalaryComponent[]
  usageLogs               UsageLog[]
  lastPaymentAt       DateTime?
  lastPaymentAmount   Float?
 
  transactions        BillingTransaction[]
  reviewCycles       ReviewCycle[]
  performanceReviews PerformanceReview[]
  employeeDocuments  EmployeeDocument[]
  announcements      Announcement[]
  companyEvents      CompanyEvent[]
  payrollConfig    PayrollConfig?
  leavePolicies    LeavePolicyConfig[]

  @@index([slug])
  @@index([stripeCustomerId])
}

model BillingTransaction {
  id                    String    @id @default(cuid())
  orderId               String    @unique
  organizationId        String
  planId                String
  billingCycle          String    @default("monthly")   // monthly | yearly
  amount                Float
  currency              String    @default("IDR")
  status                String    @default("pending")   // pending | active | failed | expired
 
  // Midtrans fields
  midtransOrderId       String?
  midtransTransactionId String?
  paymentType           String?   // gopay | bank_transfer | credit_card | etc
  paidAt                DateTime?
 
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
 
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
 
  @@index([organizationId])
  @@index([status])
}

model UsageLog {
  id             String       @id @default(cuid())
  organizationId String
  employeeCount  Int
  storageUsed    Float        @default(0)
  recordedAt     DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([recordedAt])
}

model OrganizationSettings {
  id                 String       @id @default(cuid())
  organizationId     String       @unique
  workingDaysPerWeek Int          @default(5)
  workStartTime      String       @default("09:00")
  workEndTime        String       @default("17:00")
  timezone           String       @default("Asia/Jakarta")
  annualLeaveQuota   Int          @default(12)
  sickLeaveQuota     Int          @default(12)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Employee {
  id                    String          @id @default(cuid())
  organizationId        String
  authId                String?         @unique
  email                 String
  firstName             String
  lastName              String
  phoneNumber           String?
  dateOfBirth           DateTime?
  address               String?
  employeeId            String          @unique
  departmentId          String?
  position              String
  employmentType        String          @default("full-time")
  joinDate              DateTime        @default(now())
  resignDate            DateTime?
  status                String          @default("active")
  baseSalary            Decimal         @db.Decimal(12, 2)
  currency              String          @default("IDR")
  role                  String          @default("employee")
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  managerId             String?
  attendance            Attendance[]
  managedDepartment     Department[]    @relation("DepartmentManager")
  department            Department?     @relation(fields: [departmentId], references: [id])
  manager               Employee?       @relation("ManagerSubordinates", fields: [managerId], references: [id])
  subordinates          Employee[]      @relation("ManagerSubordinates")
  organization          Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  delegatedLeaves       Leave[]         @relation("DelegatedLeaves")
  leaves                Leave[]
  leaveApprovals        LeaveApproval[] @relation("LeaveApprovals")
  leaveRequests         LeaveRequest[]
  receivedNotifications Notification[]  @relation("ReceivedNotifications")
  sentNotifications     Notification[]  @relation("SentNotifications")
  payrolls              Payroll[]
  reviewsAsEmployee  PerformanceReview[]  @relation("ReviewedEmployee")
  reviewsAsReviewer  PerformanceReview[]  @relation("ReviewerEmployee")
  goalTrackings      GoalTracking[]
  documents             EmployeeDocument[]   @relation("EmployeeDocs")
  uploadedDocuments     EmployeeDocument[]   @relation("DocumentUploader")
  authoredAnnouncements Announcement[]       @relation("AnnouncementAuthor")
  announcementReads     AnnouncementRead[]   @relation("AnnouncementReads")
  createdEvents         CompanyEvent[]       @relation("CalendarCreator")

  @@index([organizationId])
  @@index([authId])
  @@index([email])
  @@index([departmentId])
  @@index([managerId])
}

model Department {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  description    String?
  managerId      String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  manager        Employee?    @relation("DepartmentManager", fields: [managerId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employees      Employee[]
  announcements  Announcement[]  @relation("AnnouncementDept")
  calendarEvents CompanyEvent[]  @relation("CalendarDept")
  
  @@unique([organizationId, name])
  @@index([organizationId])
}

model LeaveRequest {
  id             String       @id @default(cuid())
  organizationId String
  employeeId     String
  leaveType      String
  startDate      DateTime
  endDate        DateTime
  totalDays      Int
  reason         String
  status         String       @default("pending")
  reviewedBy     String?
  reviewedAt     DateTime?
  reviewNotes    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  employee       Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([employeeId])
  @@index([status])
  @@index([startDate])
}

model LeaveApproval {
  id         String   @id @default(cuid())
  leaveId    String
  approverId String
  action     String
  comments   String?
  actionDate DateTime @default(now())
  level      Int      @default(1)
  sequence   Int      @default(1)
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  approver   Employee @relation("LeaveApprovals", fields: [approverId], references: [id])
  leave      Leave    @relation(fields: [leaveId], references: [id], onDelete: Cascade)

  @@index([leaveId])
  @@index([approverId])
  @@index([status])
  @@index([action])
}

model Attendance {
  id               String       @id @default(cuid())
  organizationId   String
  employeeId       String
  date             DateTime     @db.Date
  checkIn          DateTime?
  checkOut         DateTime?
  status           String       @default("present")
  notes            String?
  checkInLocation  String?
  checkOutLocation String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  employee         Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([organizationId])
  @@index([employeeId])
  @@index([date])
}

model Leave {
  id                     String          @id @default(cuid())
  employeeId             String
  organizationId         String
  leaveType              String
  startDate              DateTime
  endDate                DateTime
  days                   Int
  reason                 String
  attachmentUrl          String?
  status                 String          @default("pending")
  approvedBy             String?
  approvedAt             DateTime?
  rejectedReason         String?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  category               String          @default("annual")
  delegateNotes          String?
  delegateTo             String?
  documentType           String?
  endTime                String?
  isPaid                 Boolean         @default(true)
  startTime              String?
  totalHours             Float?
  currentApprovalLevel   Int             @default(1)
  requiresApprovalLevels Int             @default(1)
  delegate               Employee?       @relation("DelegatedLeaves", fields: [delegateTo], references: [id])
  employee               Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  organization           Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  approvals              LeaveApproval[]

  @@index([employeeId])
  @@index([organizationId])
  @@index([status])
  @@index([leaveType])
  @@index([delegateTo])
  @@index([startDate, endDate])
}

model Payroll {
  id                  String       @id @default(cuid())
  organizationId      String
  employeeId          String
  baseSalary          Decimal      @db.Decimal(15, 2)
  allowances          Decimal      @default(0) @db.Decimal(15, 2)
  overtime            Decimal      @default(0) @db.Decimal(15, 2)
  bonus               Decimal      @default(0) @db.Decimal(15, 2)
  otherDeductions     Decimal      @default(0) @db.Decimal(15, 2)
  grossSalary         Decimal      @db.Decimal(15, 2)
  netSalary           Decimal      @db.Decimal(15, 2)
  status              String       @default("draft")
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  absentDays          Int          @default(0)
  approvedBy          String?
  bpjsKesehatan       Decimal      @default(0) @db.Decimal(15, 2)
  bpjsKetenagakerjaan Decimal      @default(0) @db.Decimal(15, 2)
  createdBy           String?
  lateDays            Int          @default(0)
  month               Int
  notes               String?
  overtimeHours       Decimal      @default(0) @db.Decimal(5, 2)
  paidDate            DateTime?
  periodEnd           DateTime
  periodStart         DateTime
  pph21               Decimal      @default(0) @db.Decimal(15, 2)
  totalDeductions     Decimal      @db.Decimal(15, 2)
  workDays            Int          @default(0)
  year                Int
  employee            Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([employeeId, month, year])
  @@index([organizationId])
  @@index([employeeId])
  @@index([status])
  @@index([month, year])
}

model SalaryComponent {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  type           String
  amount         Decimal?     @db.Decimal(15, 2)
  percentage     Decimal?     @db.Decimal(5, 2)
  isDefault      Boolean      @default(false)
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model Notification {
  id             String       @id @default(cuid())
  organizationId String
  recipientId    String
  senderId       String?
  type           String
  title          String
  message        String
  resourceType   String?
  resourceId     String?
  isRead         Boolean      @default(false)
  readAt         DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  recipient      Employee     @relation("ReceivedNotifications", fields: [recipientId], references: [id], onDelete: Cascade)
  sender         Employee?    @relation("SentNotifications", fields: [senderId], references: [id])

  @@index([recipientId])
  @@index([organizationId])
  @@index([isRead])
  @@index([type])
  @@index([createdAt])
}

model ReviewCycle {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  type           String   // quarterly, semi_annual, annual
  startDate      DateTime
  endDate        DateTime
  status         String   @default("draft") // draft, active, completed
  description    String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  reviews      PerformanceReview[]

  @@index([organizationId])
  @@index([status])
}

model PerformanceReview {
  id             String @id @default(cuid())
  organizationId String
  cycleId        String
  employeeId     String
  reviewerId     String

  attendanceScore    Float?
  workQualityScore   Float?
  teamworkScore      Float?
  initiativeScore    Float?
  communicationScore Float?
  overallScore       Float?

  strengths      String? @db.Text
  improvements   String? @db.Text
  goals          String? @db.Text
  reviewerNotes  String? @db.Text
  selfAssessment String? @db.Text
  selfScore      Float?

  status      String    @default("pending") // pending, self_submitted, reviewed, completed
  submittedAt DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  cycle        ReviewCycle   @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  employee     Employee      @relation("ReviewedEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  reviewer     Employee      @relation("ReviewerEmployee", fields: [reviewerId], references: [id], onDelete: Cascade)
  goals_list   GoalTracking[]

  @@unique([cycleId, employeeId])
  @@index([organizationId])
  @@index([employeeId])
  @@index([reviewerId])
  @@index([status])
}

model GoalTracking {
  id          String    @id @default(cuid())
  reviewId    String
  employeeId  String
  title       String
  description String?   @db.Text
  target      String
  progress    Int       @default(0)
  status      String    @default("in_progress") // in_progress, completed, cancelled
  dueDate     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  review   PerformanceReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  employee Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@index([employeeId])
}

model EmployeeDocument {
  id             String  @id @default(cuid())
  organizationId String
  employeeId     String
  uploadedBy     String

  category    String  // contract, id_card, certificate, diploma, photo, bpjs, tax, medical, other
  name        String
  description String?  @db.Text
  fileUrl     String
  fileType    String   // pdf, jpg, png, docx, xlsx
  fileSize    Int
  isPrivate   Boolean  @default(false)
  isVerified  Boolean  @default(false)
  verifiedBy  String?
  expiresAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee     Employee     @relation("EmployeeDocs", fields: [employeeId], references: [id], onDelete: Cascade)
  uploader     Employee     @relation("DocumentUploader", fields: [uploadedBy], references: [id])

  @@index([organizationId])
  @@index([employeeId])
  @@index([category])
}

model Announcement {
  id             String   @id @default(cuid())
  organizationId String
  authorId       String

  title       String
  content     String   @db.Text
  type        String   @default("info") // info, warning, urgent, event
  isPinned    Boolean  @default(false)
  isPublished Boolean  @default(false)
  publishedAt DateTime?

  targetRoles        String?  // "all", "employee,manager"
  targetDepartmentId String?

  expiresAt      DateTime?
  attachmentUrl  String?
  attachmentName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  author           Employee          @relation("AnnouncementAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  targetDepartment Department?       @relation("AnnouncementDept", fields: [targetDepartmentId], references: [id])
  reads            AnnouncementRead[]

  @@index([organizationId])
  @@index([authorId])
  @@index([isPublished])
  @@index([isPinned])
}

model AnnouncementRead {
  id             String   @id @default(cuid())
  announcementId String
  employeeId     String
  readAt         DateTime @default(now())

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  employee     Employee     @relation("AnnouncementReads", fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([announcementId, employeeId])
  @@index([employeeId])
}

model CompanyEvent {
  id             String   @id @default(cuid())
  organizationId String
  createdBy      String

  title       String
  description String?  @db.Text
  type        String   // holiday, event, meeting, reminder, birthday, training
  color       String   @default("#3B82F6")

  startDate DateTime
  endDate   DateTime
  isAllDay  Boolean  @default(true)
  startTime String?
  endTime   String?

  isNational    Boolean  @default(false)
  isRecurring   Boolean  @default(false)
  recurringType String?

  location   String?
  meetingUrl String?

  targetRoles        String?
  targetDepartmentId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator          Employee     @relation("CalendarCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  targetDepartment Department?  @relation("CalendarDept", fields: [targetDepartmentId], references: [id])

  @@index([organizationId])
  @@index([startDate])
  @@index([type])
}

model PayrollConfig {
  id             String   @id @default(cuid())
  organizationId String   @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  bpjsKesEnabled      Boolean  @default(false)
  bpjsKesEmployee     Float    @default(1.0)
  bpjsKesEmployer     Float    @default(4.0)
  bpjsKesMaxSalary    Float?

  bpjsTkEnabled       Boolean  @default(false)
  bpjsTkJHT           Float    @default(2.0)
  bpjsTkJHTEmployer   Float    @default(3.7)
  bpjsTkJP            Float    @default(1.0)
  bpjsTkJPEmployer    Float    @default(2.0)
  bpjsTkJKK           Float    @default(0.24)
  bpjsTkJKM           Float    @default(0.3)
  bpjsTkMaxSalary     Float?

  pph21Enabled        Boolean  @default(false)
  pph21Method         String   @default("gross")
  pph21PTKP           Float    @default(54000000)
  ptkpStatus          String   @default("TK/0")

  lateDeductEnabled   Boolean  @default(false)
  lateGraceMinutes    Int      @default(15)
  lateDeductMethod    String   @default("minute_salary")
  lateDeductAmount    Float    @default(0)
  lateDeductPercent   Float    @default(0)

  earlyLeaveDeductEnabled Boolean @default(false)
  earlyLeaveDeductMethod  String  @default("minute_salary")
  earlyLeaveDeductAmount  Float   @default(0)
  earlyLeaveDeductPercent Float   @default(0)

  absentDeductEnabled Boolean @default(false)
  absentDeductMethod  String  @default("daily_salary")
  absentDeductAmount  Float   @default(0)

  overtimeEnabled     Boolean @default(true)
  overtimeRate1       Float   @default(1.5)
  overtimeRate2       Float   @default(2.0)
  overtimeRateHoliday Float   @default(2.0)
  overtimeHourlyBasis Int     @default(173)

  customAllowances    String  @default("[]")
  customDeductions    String  @default("[]")

  payrollDate         Int     @default(25)
  cutoffDate          Int     @default(20)
  salaryType          String  @default("monthly")
  workingDaysPerMonth Int     @default(22)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LeavePolicyConfig {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  leaveTypeId       String
  isEnabled         Boolean  @default(false)
  customName        String?
  maxDaysOverride   Int?
  isPaidOverride    Boolean?
  requiresApproval  Boolean  @default(true)
  requiresDocument  Boolean  @default(false)
  canCarryForward   Boolean  @default(false)
  maxCarryForward   Int?
  countWeekend      Boolean  @default(false)
  requiresDelegation Boolean @default(false)
  notes             String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, leaveTypeId])
  @@index([organizationId])
}