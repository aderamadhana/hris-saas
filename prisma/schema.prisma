// prisma/schema.prisma
// Prisma schema for HRIS SaaS with Supabase + PgBouncer compatibility

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Organization (Multi-tenancy)
model Organization {
  id                   String                @id @default(cuid())
  name                 String
  slug                 String                @unique
  logo                 String?
  subscriptionTier     String                @default("free")
  subscriptionStatus   String                @default("active")
  stripeCustomerId     String?               @unique
  stripeSubscriptionId String?               @unique
  maxEmployees         Int                   @default(10)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  employees            Employee[]
  departments          Department[]
  leaveRequests        LeaveRequest[]
  attendance           Attendance[]
  settings             OrganizationSettings?

  planType        String   @default("free")  
  planStatus      String   @default("active") 
  employeeLimit   Int      @default(5) 
  storageLimit    Float    @default(1) 
  currentPeriodEnd DateTime?     
  trialEndsAt     DateTime?   
  
  usageLogs       UsageLog[]

  payrollDayOfMonth Int      @default(25)      // Tanggal gajian (1-31)
  
  // BPJS Rates (%)
  bpjsKesehatanRate      Decimal @db.Decimal(5, 2) @default(1)    // 1% employee
  bpjsKetenagakerjaanRate Decimal @db.Decimal(5, 2) @default(2)   // 2% employee
  
  // Relations
  payrolls        Payroll[]
  salaryComponents SalaryComponent[]
  
  // NEW: Approval rules
  leaveApprovalLevels      Int     @default(1) // 1 = Manager only, 2 = Manager + HR
  autoApproveBelow         Int     @default(0) // Auto-approve if <= X days (0 = disabled)
  requireHrApprovalAbove   Int     @default(5) // Require HR if > X days

  leaves           Leave[]

  @@index([slug])
  @@index([stripeCustomerId])
}

model UsageLog {
  id              String   @id @default(cuid())
  organizationId  String
  employeeCount   Int
  storageUsed     Float    @default(0)
  recordedAt      DateTime @default(now())
  
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  @@index([organizationId])
  @@index([recordedAt])
}

// Organization Settings
model OrganizationSettings {
  id                 String       @id @default(cuid())
  organizationId     String       @unique
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workingDaysPerWeek Int          @default(5)
  workStartTime      String       @default("09:00")
  workEndTime        String       @default("17:00")
  timezone           String       @default("Asia/Jakarta")
  annualLeaveQuota   Int          @default(12)
  sickLeaveQuota     Int          @default(12)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

// Employee
model Employee {
  id                String         @id @default(cuid())
  organizationId    String
  organization      Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  authId            String?         @unique
  email             String
  firstName         String
  lastName          String
  phoneNumber       String?
  dateOfBirth       DateTime?
  address           String?
  employeeId        String         @unique
  departmentId      String?
  department        Department?    @relation(fields: [departmentId], references: [id])
  position          String
  employmentType    String         @default("full-time")
  joinDate          DateTime       @default(now())
  resignDate        DateTime?
  status            String         @default("active")
  baseSalary        Decimal        @db.Decimal(12, 2)
  currency          String         @default("IDR")
  role              String         @default("employee")
  managerId         String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  leaveRequests     LeaveRequest[]
  leaveApprovals  LeaveApproval[]  @relation("LeaveApprovals")  // ADD THIS
  attendance        Attendance[]
  payrolls          Payroll[]

  manager         Employee?        @relation("ManagerSubordinates", fields: [managerId], references: [id])
  subordinates    Employee[]       @relation("ManagerSubordinates")

  managedDepartment Department[]   @relation("DepartmentManager")
  leaves             Leave[]              @relation
  delegatedLeaves Leave[]      @relation("DelegatedLeaves")  // ADD THIS!
  
  @@index([organizationId])
  @@index([authId])
  @@index([email])
  @@index([departmentId])
  @@index([managerId])
}

// Department
model Department {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  managerId      String?
  manager        Employee?    @relation("DepartmentManager", fields: [managerId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  employees      Employee[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

// Leave Request
model LeaveRequest {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employeeId     String
  employee       Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType      String
  startDate      DateTime
  endDate        DateTime
  totalDays      Int
  reason         String
  status         String       @default("pending")
  reviewedBy     String?
  reviewedAt     DateTime?
  reviewNotes    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([employeeId])
  @@index([status])
  @@index([startDate])
}

model LeaveApproval {
  id          String   @id @default(cuid())
  leaveId     String
  approverId  String   // Manager/HR who approves
  
  // Approval action
  action      String   // approved, rejected, pending
  comments    String?  @db.Text
  actionDate  DateTime @default(now())
  
  // Approval level (for multi-level approval)
  level       Int      @default(1) // 1 = Manager, 2 = HR, 3 = Director
  sequence    Int      @default(1) // Order of approval
  
  // Status
  status      String   @default("pending") // pending, completed, skipped
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  leave       Leave    @relation(fields: [leaveId], references: [id], onDelete: Cascade)
  approver    Employee @relation("LeaveApprovals", fields: [approverId], references: [id])
  
  @@index([leaveId])
  @@index([approverId])
  @@index([status])
  @@index([action])
}

// Attendance
model Attendance {
  id               String       @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employeeId       String
  employee         Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date             DateTime     @db.Date
  checkIn          DateTime?
  checkOut         DateTime?
  status           String       @default("present")
  notes            String?
  checkInLocation  String?
  checkOutLocation String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([employeeId, date])
  @@index([organizationId])
  @@index([employeeId])
  @@index([date])
}

model Leave {
  id             String   @id @default(cuid())
  employeeId     String
  organizationId String
  
  // Leave type and dates
  leaveType      String
  startDate      DateTime
  endDate        DateTime
  days           Int
  
  // Time fields
  startTime      String?
  endTime        String?
  totalHours     Float?
  
  // Reason and documents
  reason         String   @db.Text
  attachmentUrl  String?
  documentType   String?
  
  // Delegation
  delegateTo     String?
  delegateNotes  String?
  
  // Status and approval
  status         String   @default("pending") // pending, approved, rejected, cancelled
  approvedBy     String?  // Final approver (kept for backward compatibility)
  approvedAt     DateTime?
  rejectedReason String?
  
  // NEW: Approval workflow
  currentApprovalLevel Int      @default(1)
  requiresApprovalLevels Int    @default(1) // How many levels needed
  
  // Payment and category
  isPaid         Boolean  @default(true)
  category       String   @default("annual")
  
  // Timestamps
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  // Relations
  employee       Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  delegate       Employee?        @relation("DelegatedLeaves", fields: [delegateTo], references: [id])
  approvals      LeaveApproval[]  // ADD THIS - All approval records
  
  @@index([employeeId])
  @@index([organizationId])
  @@index([status])
  @@index([leaveType])
  @@index([delegateTo])
  @@index([startDate, endDate])
}

// Payroll
model Payroll {
  id              String   @id @default(cuid())
  employeeId      String
  organizationId  String
  
  // Period
  month           Int              // 1-12
  year            Int              // 2024, 2025, etc
  periodStart     DateTime
  periodEnd       DateTime
  
  // Salary Components
  baseSalary      Decimal  @db.Decimal(15, 2)
  allowances      Decimal  @db.Decimal(15, 2) @default(0)  // Tunjangan
  overtime        Decimal  @db.Decimal(15, 2) @default(0)  // Lembur
  bonus           Decimal  @db.Decimal(15, 2) @default(0)
  
  // Deductions
  bpjsKesehatan   Decimal  @db.Decimal(15, 2) @default(0)  // BPJS Health
  bpjsKetenagakerjaan Decimal @db.Decimal(15, 2) @default(0) // BPJS Employment
  pph21           Decimal  @db.Decimal(15, 2) @default(0)  // Income Tax
  otherDeductions Decimal  @db.Decimal(15, 2) @default(0)  // Lainnya
  
  // Totals
  grossSalary     Decimal  @db.Decimal(15, 2)  // Total before deductions
  totalDeductions Decimal  @db.Decimal(15, 2)  // Total deductions
  netSalary       Decimal  @db.Decimal(15, 2)  // Take home pay
  
  // Attendance Info (for reference)
  workDays        Int      @default(0)         // Hari kerja
  absentDays      Int      @default(0)         // Hari tidak hadir
  lateDays        Int      @default(0)         // Hari terlambat
  overtimeHours   Decimal  @db.Decimal(5, 2) @default(0)
  
  // Status
  status          String   @default("draft")   // draft, approved, paid
  paidDate        DateTime?
  
  // Notes
  notes           String?
  
  // Metadata
  createdBy       String?  // Employee ID who created
  approvedBy      String?  // Employee ID who approved
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  employee        Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  @@unique([employeeId, month, year])
  @@index([organizationId])
  @@index([employeeId])
  @@index([status])
  @@index([month, year])
}

// Salary Component Template (for allowances, bonuses, etc)
model SalaryComponent {
  id              String   @id @default(cuid())
  organizationId  String
  
  name            String   // e.g., "Transport Allowance", "Meal Allowance"
  type            String   // allowance, deduction, bonus
  amount          Decimal? @db.Decimal(15, 2)  // Fixed amount (optional)
  percentage      Decimal? @db.Decimal(5, 2)   // % of base salary (optional)
  
  // Apply to
  isDefault       Boolean  @default(false)     // Auto-apply to all employees
  
  // Metadata
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  @@index([organizationId])
}
